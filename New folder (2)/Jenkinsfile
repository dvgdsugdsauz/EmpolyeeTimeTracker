pipeline {
    agent any

    environment {
        DEPLOY_SERVER = '192.168.1.104'
        DEPLOY_USER   = 'ubuntu'
        DEPLOY_DIR    = '/opt/timetracker'
        JAR_NAME      = 'employee-timetracker-1.0.0.jar'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/dvgdsugdsauz/EmpolyeeTimeTracker.git'
            }
        }

        stage('Build Backend') {
            steps {
                dir('New folder (2)/employee-timetracker-backend') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                nodejs(nodeJSInstallationName: 'nodejs') {
                    sh '''
                        echo "VITE_API_URL=http://192.168.1.104" > "New folder (2)/employee-timetracker/.env"
                        cd "New folder (2)/employee-timetracker" && npm install && npm run build
                    '''
                }
            }
        }

        stage('Deploy to Server') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'deploy-server-ssh', usernameVariable: 'SSH_USER', passwordVariable: 'SSH_PASS')]) {
                    sh """
                        sshpass -p "\$SSH_PASS" ssh -o StrictHostKeyChecking=no \$SSH_USER@${DEPLOY_SERVER} 'mkdir -p ${DEPLOY_DIR}/frontend'
                        sshpass -p "\$SSH_PASS" scp -o StrictHostKeyChecking=no "New folder (2)/employee-timetracker-backend/target/${JAR_NAME}" \$SSH_USER@${DEPLOY_SERVER}:${DEPLOY_DIR}/
                        sshpass -p "\$SSH_PASS" scp -o StrictHostKeyChecking=no -r "New folder (2)/employee-timetracker/dist/." \$SSH_USER@${DEPLOY_SERVER}:${DEPLOY_DIR}/frontend/
                        sshpass -p "\$SSH_PASS" scp -o StrictHostKeyChecking=no "New folder (2)/deploy.sh" \$SSH_USER@${DEPLOY_SERVER}:${DEPLOY_DIR}/
                        sshpass -p "\$SSH_PASS" ssh -o StrictHostKeyChecking=no \$SSH_USER@${DEPLOY_SERVER} 'chmod +x ${DEPLOY_DIR}/deploy.sh && ${DEPLOY_DIR}/deploy.sh'
                    """
                }
            }
        }
    }

    post {
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed!'
        }
    }
}

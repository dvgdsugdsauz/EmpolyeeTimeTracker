pipeline {
    agent any

    environment {
        DEPLOY_SERVER = '192.168.1.104'
        DEPLOY_USER   = 'ubuntu'
        DEPLOY_DIR    = '/opt/timetracker'
        JAR_NAME      = 'employee-timetracker-1.0.0.jar'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/dvgdsugdsauz/EmpolyeeTimeTracker.git'
            }
        }

        stage('Build Backend') {
            steps {
                dir('New folder (2)/employee-timetracker-backend') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                nodejs(nodeJSInstallationName: 'nodejs') {
                    sh 'cd "New folder (2)/employee-timetracker" && npm install && npm run build'
                }
            }
        }

        stage('Deploy to Server') {
            steps {
                sshagent(credentials: ['deploy-server-ssh']) {

                    // Create deploy directory on server
                    sh "ssh -o StrictHostKeyChecking=no ${DEPLOY_USER}@${DEPLOY_SERVER} 'mkdir -p ${DEPLOY_DIR}/frontend'"

                    // Copy backend JAR
                    sh "scp 'New folder (2)/employee-timetracker-backend/target/${JAR_NAME}' ${DEPLOY_USER}@${DEPLOY_SERVER}:${DEPLOY_DIR}/"

                    // Copy frontend build
                    sh "scp -r 'New folder (2)/employee-timetracker/dist/'* ${DEPLOY_USER}@${DEPLOY_SERVER}:${DEPLOY_DIR}/frontend/"

                    // Copy deploy script and run it
                    sh "scp 'New folder (2)/deploy.sh' ${DEPLOY_USER}@${DEPLOY_SERVER}:${DEPLOY_DIR}/"
                    sh "ssh ${DEPLOY_USER}@${DEPLOY_SERVER} 'chmod +x ${DEPLOY_DIR}/deploy.sh && ${DEPLOY_DIR}/deploy.sh'"
                }
            }
        }
    }

    post {
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed!'
        }
    }
}
